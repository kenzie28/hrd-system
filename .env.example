# Django (required for production)
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=*

# Optional: auto-create Django superuser on first container start
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=change-me
DJANGO_SUPERUSER_EMAIL=admin@example.com

# Optional: payroll import (only if using payroll sync)
# PAYROLL_DB_HOST=192.168.0.224
# PAYROLL_DB_PORT=3306
# PAYROLL_DB_USER=admin
# PAYROLL_DB_PASSWORD=
# PAYROLL_DB_NAME=payroll
